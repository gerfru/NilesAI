    {
      "parameters": {
        "jsCode": "// Format result and normalize phone number\nconst results = $input.all();\nconst searchTerm = $('Parse AI Output').first().json.target || '';\nconst messageText = $('Parse AI Output').first().json.text || '';\n\nif (results.length === 0 || !results[0].json.full_name) {\n  throw new Error(`Kein Kontakt gefunden für \"${searchTerm}\"`);\n}\n\nconst bestMatch = results[0].json;\nconsole.log(`Best match: \"${bestMatch.full_name}\"`);\n\n// Telefonnummer priorisieren: Mobil > Primary > Work\nlet phone = bestMatch.phone_mobile || bestMatch.phone_primary || bestMatch.phone_work;\n\nif (!phone) {\n  throw new Error(`Kontakt \"${bestMatch.full_name}\" hat keine Telefonnummer`);\n}\n\n// Normalisierung für WhatsApp\nphone = phone.replace(/[\\s\\-\\(\\)\\.]/g, '');\nphone = phone.replace(/^\\+/, '');\nphone = phone.replace(/^00/, '');\nif (phone.startsWith('0')) {\n  phone = '43' + phone.substring(1);\n}\n\nreturn [{\n  json: {\n    number: phone,\n    text: messageText,\n    contactName: bestMatch.full_name\n  }\n}];"
      },
