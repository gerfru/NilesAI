      "name": "When chat message received",
      "webhookId": "c8af9ddc-3a28-4114-ac8e-9e128243eec4"
    },
    {
      "parameters": {
        "options": {
          "systemMessage": "Du bist ein WhatsApp-Nachrichtenparser. Extrahiere aus der Benutzeranfrage folgende Informationen und gib sie als JSON zurück:\n\n{\n  \"isGroup\": true/false,\n  \"target\": \"Gruppenname\" oder \"Telefonnummer\" oder \"Kontaktname\",\n  \"text\": \"Der zu sendende Nachrichtentext\"\n}\n\nREGELN:\n1. isGroup = true wenn der Benutzer \"Gruppe\" erwähnt oder einen Gruppennamen nennt\n2. isGroup = false wenn eine Telefonnummer ODER ein Kontaktname angegeben wird\n3. target = Gruppenname (z.B. \"Yolo Graz\") ODER Telefonnummer (normalisiert ohne +, 00, Leerzeichen) ODER Kontaktname (z.B. \"Max\", \"Gerald\")\n4. text = Der EXAKTE Nachrichtentext wie vom Benutzer formuliert\n\nBEISPIELE:\n\"sende an +436605875573 mit 'Hi'\" → {\"isGroup\": false, \"target\": \"436605875573\", \"text\": \"Hi\"}\n\"sende an Gruppe Familie mit 'Hallo!'\" → {\"isGroup\": true, \"target\": \"Familie\", \"text\": \"Hallo!\"}\n\"schreib der Yolo Graz Gruppe 'Hey Leute'\" → {\"isGroup\": true, \"target\": \"Yolo Graz\", \"text\": \"Hey Leute\"}\n\"sende an Max mit 'Treffen um 14 Uhr'\" → {\"isGroup\": false, \"target\": \"Max\", \"text\": \"Treffen um 14 Uhr\"}\n\"schick Gerald die Nachricht 'Bist du da?'\" → {\"isGroup\": false, \"target\": \"Gerald\", \"text\": \"Bist du da?\"}\n\nGib NUR das JSON zurück, keine zusätzlichen Erklärungen."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [-720, 192],
      "id": "1c6daad3-67cb-46fe-a773-39eab64a4f18",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "value": "qwen2.5-coder-7b-instruct-mlx",
          "mode": "list",
          "cachedResultName": "qwen2.5-coder-7b-instruct-mlx"
        },
        "responsesApiEnabled": false,
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [-720, 400],
      "id": "ae79546a-9aaf-4c01-91d0-5db9982708e7",
      "name": "Qwen 2.5 7B MLX",
      "alwaysOutputData": false,
      "executeOnce": false,
      "credentials": {
        "openAiApi": {
          "id": "AqnBdqvoLrHHdaVG",
          "name": "Local Qwen"
        }
