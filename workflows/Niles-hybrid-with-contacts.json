    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT full_name, first_name, last_name, phone_primary, phone_mobile, phone_work\nFROM contacts\nWHERE full_name ILIKE '%' || $1 || '%'\n   OR first_name ILIKE '%' || $1 || '%'\n   OR last_name ILIKE '%' || $1 || '%'\nORDER BY\n    CASE\n        WHEN LOWER(full_name) = LOWER($1) THEN 1\n        WHEN LOWER(full_name) LIKE LOWER($1) || '%' THEN 2\n        WHEN LOWER(full_name) LIKE '%' || LOWER($1) || '%' THEN 3\n        ELSE 4\n    END,\n    full_name ASC\nLIMIT 5;",
        "options": {
          "queryParameters": "={{ $json.target }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [200, 520],
      "id": "pg-search-contact",
      "name": "Search Contact",
      "credentials": {
        "postgres": {
          "id": "",
          "name": "Niles PostgreSQL"
        }
      }
