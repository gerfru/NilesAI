      "id": "d64a723e-3ec8-4c32-9eb1-5e1a5d83305c",
      "name": "Fetch WhatsApp Groups"
    },
    {
      "parameters": {
        "jsCode": "const groupName = $('Parse AI Output').first().json.groupName;\n\n// Get all groups from previous node (n8n splits array into multiple items)\nconst groups = $input.all().map(item => item.json);\n\nif (groups.length === 0) {\n  throw new Error('Keine WhatsApp-Gruppen verfügbar. Ist WhatsApp verbunden?');\n}\n\n// Find matching group using partial match (case-insensitive)\nconst matchedGroup = groups.find(g =>\n  (g.subject?.toLowerCase() || '').includes(groupName)\n);\n\nif (!matchedGroup) {\n  const availableGroups = groups.map(g => g.subject).filter(Boolean).join(', ');\n  throw new Error(`Gruppe \"${groupName}\" wurde nicht gefunden. Verfügbare Gruppen: ${availableGroups || '(keine)'}`);\n}\n\n// Return the group JID (format: 120363xxx@g.us)\nreturn {\n  number: matchedGroup.id,\n  text: $('Parse AI Output').first().json.text,\n  groupFound: true,\n  groupName: matchedGroup.subject\n};"
      },
