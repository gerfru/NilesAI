      "name": "When chat message received",
      "webhookId": "c8af9ddc-3a28-4114-ac8e-9e128243eec4"
    },
    {
      "parameters": {
        "options": {
          "systemMessage": "Du bist ein WhatsApp-Nachrichtenparser. Extrahiere aus der Benutzeranfrage folgende Informationen und gib sie als JSON zurück:\n\n{\n  \"isGroup\": true/false,\n  \"target\": \"Gruppenname\" oder \"Telefonnummer\",\n  \"text\": \"Der zu sendende Nachrichtentext\"\n}\n\nREGELN:\n1. isGroup = true wenn der Benutzer \"Gruppe\" erwähnt oder einen Gruppennamen nennt\n2. isGroup = false wenn eine Telefonnummer angegeben wird\n3. target = Gruppenname (z.B. \"Group Chat\") ODER Telefonnummer (normalisiert ohne +, 00, Leerzeichen)\n4. text = Der EXAKTE Nachrichtentext wie vom Benutzer formuliert\n\nBEISPIELE:\n\"sende an +436601234567 mit 'Hi'\" → {\"isGroup\": false, \"target\": \"436601234567\", \"text\": \"Hi\"}\n\"sende an Gruppe Family Group mit 'Hallo!'\" → {\"isGroup\": true, \"target\": \"Family Group\", \"text\": \"Hallo!\"}\n\"schreib der Group Chat Gruppe 'Hey Leute'\" → {\"isGroup\": true, \"target\": \"Group Chat\", \"text\": \"Hey Leute\"}\n\"sende eine Whatsapp Nachricht an die Gruppe \\\"Group Chat\\\" mit der Nachricht \\\"Hey wie geht's\\\"?\" → {\"isGroup\": true, \"target\": \"Group Chat\", \"text\": \"Hey wie geht's\"}\n\nGib NUR das JSON zurück, keine zusätzlichen Erklärungen."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -720,
        192
      ],
      "id": "1c6daad3-67cb-46fe-a773-39eab64a4f18",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "value": "qwen2.5-coder-7b-instruct-mlx",
          "mode": "list",
          "cachedResultName": "qwen2.5-coder-7b-instruct-mlx"
        },
        "responsesApiEnabled": false,
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
        -720,
        400
      ],
      "id": "ae79546a-9aaf-4c01-91d0-5db9982708e7",
      "name": "Qwen 2.5 7B MLX",
      "alwaysOutputData": false,
      "executeOnce": false,
      "credentials": {
        "openAiApi": {
          "id": "AqnBdqvoLrHHdaVG",
          "name": "Local Qwen"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse AI Agent output\nconst aiOutput = $json.output || '';\n\n// Try to extract JSON from AI response\nlet parsed;\ntry {\n  // Remove markdown code blocks if present\n  const cleaned = aiOutput.replace(/```json\\n?|```\\n?/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error(`Failed to parse AI output as JSON: ${aiOutput}`);\n}\n\nconst isGroup = parsed.isGroup === true;\nconst target = parsed.target || '';\nconst text = parsed.text || '';\n\nif (!target || !text) {\n  throw new Error('AI did not extract target and text correctly');\n}\n\nreturn {\n  isGroup: isGroup,\n  target: target,\n  text: text,\n  // For phone: normalize the number\n  number: isGroup ? '' : target.replace(/[\\s\\+]/g, '').replace(/^00/, ''),\n  // For group: store name for matching\n  groupName: isGroup ? target.toLowerCase() : ''\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        192
      ],
      "id": "755eda90-c399-46fc-be72-93b4b862ed7b",
      "name": "Parse AI Output"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "check-is-group",
              "operator": {
                "name": "filter.operator.equals",
                "type": "boolean",
                "operation": "equals"
              },
              "leftValue": "={{ $json.isGroup }}",
              "rightValue": true
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
