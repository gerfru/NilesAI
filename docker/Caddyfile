# Niles AI - Caddy Reverse Proxy
# Self-signed TLS certificates (tls internal)
# Hostnames/IPs are configured via environment variables (see .env.example)

{
	default_sni localhost
}

(security_headers) {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}
}

# Niles Core API (:443)
{$CADDY_HOSTS_443:https://localhost} {
	tls internal
	import security_headers
	log {
		output stdout
		format json
		level INFO
	}
	reverse_proxy niles_core:8000
}

# Evolution API (:8443)
{$CADDY_HOSTS_8443:https://localhost:8443} {
	tls internal
	import security_headers
	log {
		output stdout
		format json
		level INFO
	}
	reverse_proxy evolution_api:8080
}

# Vikunja (Todos) — Port 3457
{$CADDY_HOSTS_3457:https://localhost:3457} {
	tls internal
	import security_headers
	log {
		output stdout
		format json
		level INFO
	}
	reverse_proxy vikunja:3456
}

# PulseBase (Garmin Dashboard) — garmin.local
{$CADDY_HOSTS_GARMIN:https://garmin.local} {
	tls internal
	import security_headers
	log {
		output stdout
		format json
		level INFO
	}
	reverse_proxy garmin-api:8000
}
