FROM python:3.12-slim

WORKDIR /app

# Install uv for fast dependency management
RUN pip install uv

# Copy dependency files and install (cached layer)
COPY pyproject.toml .
COPY src/ ./src/
RUN uv pip install --system -e ".[dev]"

# Copy config
COPY config/ ./config/

# src/niles must be importable as "niles"
ENV PYTHONPATH=/app/src

CMD ["uvicorn", "niles.main:app", "--host", "0.0.0.0", "--port", "8000"]
