# n8n API Key (Settings > API > Create API Key)
# Used by: import-workflows.sh script
N8N_API_KEY=your-n8n-api-key-here

# Evolution API Configuration
# Used by: Evolution API container + n8n workflows (via $env.EVOLUTION_API_KEY)
EVOLUTION_API_KEY=your-secure-api-key-here

# PostgreSQL Database
# Used by: Evolution API + n8n contact sync/lookup workflows
# Connection: postgresql://evolution:PASSWORD@evolution_postgres:5432/evolution_db
EVOLUTION_POSTGRES_PASSWORD=your-secure-database-password-here

# Niles API Key (for /chat endpoint authentication)
# Auto-generated at startup if not set (retrieve with: docker exec niles_core printenv NILES_API_KEY)
# Set manually for a stable key across container restarts
#NILES_API_KEY=

# CardDAV (mailbox.org) – Used by: Niles Core contact sync
CARDDAV_USER=your-carddav-username
CARDDAV_PASSWORD=your-carddav-password
