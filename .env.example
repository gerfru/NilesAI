# ============================================================
# Niles AI — Environment Configuration
# ============================================================
# Nur Werte, die VOR dem Start gesetzt sein muessen.
# Alles andere (LLM, Briefing, Wetter, Signal, CardDAV, ...)
# wird ueber die Settings-UI konfiguriert.
# ============================================================

# --- Pflicht (App startet ohne diese nicht) ------------------

# Evolution API — WhatsApp-Bridge
EVOLUTION_API_KEY=your-secure-api-key-here

# PostgreSQL — gemeinsame Datenbank fuer Evolution + Niles
EVOLUTION_POSTGRES_PASSWORD=your-secure-database-password-here

# Credential Encryption (Fernet AES-128-CBC + HMAC)
# Verschluesselt Drittanbieter-Credentials in der Datenbank
# (CalDAV-Passwoerter, Notion Token, Vikunja Token, CardDAV-Passwoerter)
# Generate: python3.14 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# --- Empfohlen -----------------------------------------------

# Session-Secret (Cookie-Signierung + Vikunja-Passwort-Ableitung)
# Auto-generiert wenn leer, aber dann aendern sich Sessions bei jedem Restart.
#SESSION_SECRET=

# Niles API Key (fuer /chat REST-Endpunkt)
# Auto-generiert wenn leer (auslesen: docker exec niles_core printenv NILES_API_KEY)
#NILES_API_KEY=

# --- Google OAuth (Login) ------------------------------------

# Credentials: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://<YOUR-HOST>/ui/callback/google
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
# Erlaubte E-Mails (kommagetrennt, leer = alle)
#GOOGLE_ALLOWED_EMAILS=

# Base-URL fuer OAuth-Redirects (z.B. https://niles.example.ts.net)
# Pflicht wenn hinter Reverse-Proxy; sonst aus Request-Headers abgeleitet.
#BASE_URL=

# --- Vikunja (Todo/Task Management) --------------------------

# Accounts werden automatisch beim Niles-Login erstellt.
# Voraussetzung: CREATE DATABASE vikunja_db OWNER evolution;
#VIKUNJA_JWT_SECRET=<openssl rand -base64 32>
#VIKUNJA_API_URL=http://vikunja:3456/api/v1
# Oeffentliche URL fuer Nav-Link + Vikunja-Frontend
#VIKUNJA_PUBLIC_URL=https://vikunja.home.lab

# --- CalDAV (initiale Migration) -----------------------------

# Wird beim ersten Start in die DB migriert.
# Danach nur noch ueber Settings > Kalenderquellen verwaltet.
#CALDAV_URL=https://dav.example.com/caldav/
#CALDAV_USER=
#CALDAV_PASSWORD=
#FEATURE_CALDAV_SYNC=false

# --- Web Search (SearXNG, optional) --------------------------

#FEATURE_SEARCH=false
#SEARXNG_URL=http://searxng:8080
#SEARXNG_SECRET_KEY=<openssl rand -hex 32>

# --- Notion RAG (Wissensdatenbank, optional) -----------------

# Notion Internal Integration Token (ntn_****)
# Erstellen: https://www.notion.so/profile/integrations (Read-only!)
#NOTION_TOKEN=
#FEATURE_NOTION=false
#NOTION_SYNC_INTERVAL=30
#NOTION_EMBEDDING_MODEL=nomic-embed-text-v2-moe

# --- Erweitert (selten noetig) --------------------------------

# Postgres-Port auf Host exposen (Debugging)
#POSTGRES_HOST_PORT=5432

# Interner Webhook-Endpunkt (Evolution API -> Niles Core)
#WEBHOOK_BASE_URL=http://niles_core:8000

# Log-Level (DEBUG erlaubt Start ohne CREDENTIAL_ENCRYPTION_KEY)
#LOG_LEVEL=INFO
