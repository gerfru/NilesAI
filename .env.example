# Evolution API Configuration
# Used by: Evolution API container + Niles Core webhook
EVOLUTION_API_KEY=your-secure-api-key-here

# PostgreSQL Database
# Used by: Evolution API + Niles Core
# Connection: postgresql://evolution:PASSWORD@evolution_postgres:5432/evolution_db
EVOLUTION_POSTGRES_PASSWORD=your-secure-database-password-here

# Niles API Key (for /chat endpoint authentication)
# Auto-generated at startup if not set (retrieve with: docker exec niles_core printenv NILES_API_KEY)
# Set manually for a stable key across container restarts
#NILES_API_KEY=

# Timezone – Used by: CalDAV/CalendarAction for datetime formatting
# Default: Europe/Vienna
#TIMEZONE=Europe/Vienna

# CardDAV (mailbox.org) – Used by: Niles Core contact sync
# Optional when FEATURE_CARDDAV_SYNC=false
CARDDAV_USER=your-carddav-username
CARDDAV_PASSWORD=your-carddav-password
FEATURE_CARDDAV_SYNC=false

# CalDAV (mailbox.org) – Used by: Niles Core calendar sync
# Optional when FEATURE_CALDAV_SYNC=false
CALDAV_URL=https://dav.example.com/caldav/
CALDAV_USER=your-caldav-username
CALDAV_PASSWORD=your-caldav-password
FEATURE_CALDAV_SYNC=false

# Google OAuth – Used by: Web UI login
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://<YOUR-HOST>/ui/callback/google
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
# Comma-separated list of allowed emails (empty = all Google accounts allowed)
#GOOGLE_ALLOWED_EMAILS=user1@gmail.com,user2@gmail.com
