# Evolution API Configuration
# Used by: Evolution API container + Niles Core webhook
EVOLUTION_API_KEY=your-secure-api-key-here

# PostgreSQL Database
# Used by: Evolution API + Niles Core
# Connection: postgresql://evolution:PASSWORD@evolution_postgres:5432/evolution_db
EVOLUTION_POSTGRES_PASSWORD=your-secure-database-password-here

# Expose Postgres port for local debugging (default: random port, not discoverable)
# Uncomment to bind to a fixed port:
#POSTGRES_HOST_PORT=5432

# Niles API Key (for /chat endpoint authentication)
# Auto-generated at startup if not set (retrieve with: docker exec niles_core printenv NILES_API_KEY)
# Set manually for a stable key across container restarts
#NILES_API_KEY=

# Session signing secret (separate from API key, for cookie security)
# Auto-generated at startup if not set. Set manually for stable sessions across restarts.
#SESSION_SECRET=

# Base URL for OAuth redirect URI (e.g. https://niles.example.ts.net)
# Required when using Google OAuth behind a reverse proxy
#BASE_URL=

# LLM Backend - Used by: Niles Core agent
# Ollama runs natively on the host for full GPU performance.
# Default: http://host.docker.internal:11434/v1 (Ollama via Docker host)
#LLM_BASE_URL=http://host.docker.internal:11434/v1
#LLM_MODEL=llama3.1:8b

# Timezone - Used by: CalDAV/CalendarAction for datetime formatting
# Default: Europe/Vienna
#TIMEZONE=Europe/Vienna

# CardDAV (mailbox.org) - Used by: Niles Core contact sync
# Optional when FEATURE_CARDDAV_SYNC=false
CARDDAV_USER=your-carddav-username
CARDDAV_PASSWORD=your-carddav-password
FEATURE_CARDDAV_SYNC=false

# CalDAV (Legacy) - Wird beim ersten Start automatisch in die DB migriert.
# Neue Kalenderquellen (ICS, CalDAV) werden ueber die Web-UI verwaltet (Settings > Kalenderquellen).
# Diese Werte werden nur noch fuer die initiale Migration verwendet.
CALDAV_URL=https://dav.example.com/caldav/
CALDAV_USER=your-caldav-username
CALDAV_PASSWORD=your-caldav-password
FEATURE_CALDAV_SYNC=false

# Vikunja (Todo/Task Management) - Optional
# Setup: docker compose up -d vikunja, dann https://localhost:3457 fuer API Token
# Hinweis: Vikunja benoetigt eigene DB: CREATE DATABASE vikunja_db OWNER evolution;
#VIKUNJA_JWT_SECRET=<generierter-secret>
#VIKUNJA_API_URL=http://vikunja:3456/api/v1
#VIKUNJA_API_TOKEN=<api-token-nach-setup>
#FEATURE_VIKUNJA=false
# Public URL for Vikunja (used in email links, password-reset, etc.)
# Default: https://localhost:3457
#VIKUNJA_PUBLIC_URL=https://niles.example.ts.net:3457

# Briefing (Tägliche/Wöchentliche Übersicht via WhatsApp)
# Sendet automatisch Zusammenfassungen an die verbundene WhatsApp-Nummer.
# Voraussetzung: WhatsApp muss in der Web-UI verbunden sein.
#FEATURE_BRIEFING_DAILY=false
#FEATURE_BRIEFING_WEEKLY=false
#BRIEFING_DAILY_TIME=07:30
#BRIEFING_WEEKLY_TIME=07:15

# WhatsApp Feature Flags
# Darf Niles via send_whatsapp-Tool an andere Personen senden?
# Self-Chat Antworten ("Hey Niles") sind immer aktiv.
#FEATURE_WHATSAPP_SEND_OTHERS=true

# Internal base URL for Evolution API webhooks (Docker-internal, no TLS needed).
# Only change if your Docker service name or port differ from the defaults.
#WEBHOOK_BASE_URL=http://niles_core:8000

# Google OAuth - Used by: Web UI login + Google Calendar sync
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Redirect URIs (both required):
#   https://<YOUR-HOST>/ui/callback/google           (login)
#   https://<YOUR-HOST>/ui/callback/google/calendar   (calendar connect)
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
# Comma-separated list of allowed emails (empty = all Google accounts allowed)
#GOOGLE_ALLOWED_EMAILS=user1@gmail.com,user2@gmail.com
